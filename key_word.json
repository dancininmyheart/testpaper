    {
      "id": "arith.properties.commutative_add",
      "name": "加法交换律",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第一学段(1-2)",
      "canonical": [
        "a + b = b + a"
      ],
      "procedure": [
        "用于凑整、简便计算、检验运算等价变形"
      ],
      "prereq": [],
      "short_name": "加法交换律"
    },
    {
      "id": "arith.properties.commutative_mul",
      "name": "乘法交换律",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第一学段(1-2)",
      "canonical": [
        "a × b = b × a"
      ],
      "procedure": [
        "用于简便计算与因式调序"
      ],
      "prereq": [],
      "short_name": "乘法交换律"
    },
    {
      "id": "arith.properties.associative_add",
      "name": "加法结合律",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第一学段(1-2)",
      "canonical": [
        "(a + b) + c = a + (b + c)"
      ],
      "procedure": [
        "配对凑整：先把能凑整的一组括起来"
      ],
      "prereq": [],
      "short_name": "加法结合律"
    },
    {
      "id": "arith.properties.associative_mul",
      "name": "乘法结合律",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第二学段(3-4)",
      "canonical": [
        "(a × b) × c = a × (b × c)"
      ],
      "procedure": [
        "把方便的因子先乘（如 25×4）"
      ],
      "prereq": [
        "arith.properties.commutative_mul"
      ],
      "short_name": "乘法结合律"
    },
    {
      "id": "arith.properties.distributive",
      "name": "乘法分配律",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第二学段(3-4)",
      "canonical": [
        "a(b + c) = ab + ac",
        "(a + b)c = ac + bc"
      ],
      "procedure": [
        "简便计算：拆分成易算的两项；代数展开的基础"
      ],
      "prereq": [
        "arith.properties.associative_mul",
        "arith.properties.associative_add"
      ],
      "short_name": "乘法分配律"
    },
    {
      "id": "fraction.concept.value",
      "name": "分数的意义（整体-部分 / 数轴表示）",
      "type": "concept",
      "stage": "小学",
      "grade_band": "小学-第三学段(5)",
      "canonical": [
        "把单位“1”平均分成 b 份，取其中 a 份记为 a/b"
      ],
      "procedure": [
        "能在数轴上定位分数；理解分子分母含义"
      ],
      "prereq": [],
      "short_name": "分数的意义（整体-部分 / 数轴表示）"
    },
    {
      "id": "fraction.formula.equivalent",
      "name": "等值分数（基本性质）",
      "type": "theorem",
      "stage": "小学",
      "grade_band": "小学-第三学段(5)",
      "canonical": [
        "a/b = (a×k)/(b×k)  (k≠0)"
      ],
      "procedure": [
        "通分/约分的理论依据"
      ],
      "prereq": [
        "fraction.concept.value",
        "arith.properties.commutative_mul"
      ],
      "short_name": "等值分数（基本性质）"
    },
    {
      "id": "fraction.method.simplify",
      "name": "约分（最大公因数法）",
      "type": "method",
      "stage": "小学",
      "grade_band": "小学-第三学段(5)",
      "canonical": [
        "a/b → (a÷g)/(b÷g),  g = gcd(a,b)"
      ],
      "procedure": [
        "求 a 与 b 的最大公因数 g",
        "分子分母同时除以 g",
        "检验是否为最简分数"
      ],
      "prereq": [
        "fraction.formula.equivalent"
      ],
      "short_name": "约分（最大公因数法）"
    },
    {
      "id": "fraction.formula.add_sub_same_den",
      "name": "同分母分数加减",
      "type": "formula",
      "stage": "小学",
      "grade_band": "小学-第三学段(5)",
      "canonical": [
        "a/b ± c/b = (a±c)/b"
      ],
      "procedure": [
        "分母不变，分子相加减"
      ],
      "prereq": [
        "fraction.concept.value"
      ],
      "short_name": "同分母分数加减"
    },
    {
      "id": "fraction.formula.add_sub_diff_den",
      "name": "异分母分数加减（通分法）",
      "type": "method",
      "stage": "小学",
      "grade_band": "小学-第三学段(5)",
      "canonical": [
        "a/b ± c/d = (ad ± bc) / bd （或用最小公倍数通分）"
      ],
      "procedure": [
        "求分母的最小公倍数 L",
        "把各分数化为同分母 L",
        "按同分母规则加减",
        "必要时约分"
      ],
      "prereq": [
        "fraction.formula.equivalent",
        "fraction.formula.add_sub_same_den"
      ],
      "short_name": "异分母分数加减（通分法）"
    },
    {
      "id": "fraction.formula.mul",
      "name": "分数乘法",
      "type": "formula",
      "stage": "小学",
      "grade_band": "小学-第三学段(5-6)",
      "canonical": [
        "(a/b)×(c/d) = (ac)/(bd)"
      ],
      "procedure": [
        "能先约分再相乘以简化"
      ],
      "prereq": [
        "fraction.method.simplify"
      ],
      "short_name": "分数乘法"
    },
    {
      "id": "fraction.formula.div",
      "name": "分数除法（乘倒数）",
      "type": "formula",
      "stage": "小学",
      "grade_band": "小学-第三学段(6)",
      "canonical": [
        "(a/b)÷(c/d) = (a/b)×(d/c) （c≠0）"
      ],
      "procedure": [
        "先写成乘法再计算；注意除数不为 0"
      ],
      "prereq": [
        "fraction.formula.mul"
      ],
      "short_name": "分数除法（乘倒数）"
    },
    {
      "id": "percent.formula.convert",
      "name": "分数/小数/百分数互化",
      "type": "skill",
      "stage": "小学",
      "grade_band": "小学-第三学段(6)",
      "canonical": [
        "p% = p/100 = 0.p（按小数点移动）"
