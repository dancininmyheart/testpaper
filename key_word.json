        "a/b = x/d ⇒ ad = bx ⇒ x = ad/b"
      ],
      "procedure": [
        "写等式→交叉相乘→解未知数→检验"
      ],
      "prereq": [
        "ratio.concept.proportion"
      ],
      "short_name": "解比例（交叉相乘法）"
    },
