  "mineru": {
    "profiles": {
      "default": {
        "base_url": "https://mineru.net/api/v4",
        "api_key_env": "MINERU_API_KEY",
        "api_key": "",
        "model_version": "vlm",
        "language": "ch",
        "timeout_sec": 120,
        "result_timeout_sec": 900,
        "poll_interval_sec": 5,
        "use_env_proxy": false
      }
    },
    "kie": {
      "base_url": "https://mineru.net/api/kie",
      "pipeline_id": "YOUR_KIE_PIPELINE_ID",
      "timeout_sec": 30,
      "result_timeout_sec": 60,
      "poll_interval_sec": 5,
      "use_env_proxy": false
    }
  },
  "openai_profiles": {
    "vision_tagger": {
      "profile_role": "vision",
      "runtime": "langchain",
      "provider": "openai_compatible",
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "model": "doubao-seed-2-0-pro-260215",
      "api_key_env": "ARK_API_KEY",
      "api_key": "",
      "timeout_sec": 300,
      "max_retries": 2,
      "backoff_base_sec": 1.5,
      "min_interval_sec": 0.0,
      "use_env_proxy": false,
      "use_responses_api": false,
      "enable_thinking": false,
      "detail": "low",
      "paper_batch_size": 1,
      "answer_batch_size": 1,
      "question_page_batch_size": 1,
      "question_chunk_size": 8,
      "route_chunk_size": 4,
      "score_chunk_size": 3,
      "answer_chunk_size": 8,
      "paper_concurrency": 8,
      "answer_route_concurrency": 8,
      "answer_concurrency": 8,
      "objective_chunk_size": 8,
      "subjective_chunk_size": 2,
      "subjective_question_types": [
        "solution",
        "application",
        "unknown"
      ],
      "text_profile": "text_analysis",
      "max_repair_rounds": 1,
      "repair_trigger_unseen": true,
      "repair_trigger_unmatched": true,
      "min_answer_confidence_for_skip_repair": 0.75,
      "answer_segment_conf": 0.1,
      "max_tokens": 65536,
      "answer_trace_save_debug_json": false,
      "answer_trace_debug_output_dir": "outputs/answer_trace_debug",
      "knowledge_tagging_mode": "fast",
      "question_full_discovery_enabled": true,
      "blind_diagnosis_max_items": 12,
      "profile_mode": "llm"
