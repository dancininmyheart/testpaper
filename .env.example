# LLM API Keys
# 复制此文件为 .env 并填入真实的 API 密钥
ARK_API_KEY=your_ark_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 平台配置（可选）
# APP_DB_PATH=outputs/platform/app.db
# APP_STORAGE_ROOT=outputs/platform/storage
# LLM_CONFIG_PATH=llm_config.json
# DEMO_MOCK_MODE=true
# WORKER_ENABLED=true
# SESSION_TTL_HOURS=12
# CORS_ALLOW_ORIGINS=*
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_TEACHER_USERNAME=teacher
# DEFAULT_TEACHER_PASSWORD=teacher123

# 相似试卷生成:provider 与 key
EXAM_GEN_ACTIVE_PROVIDER=packy
PACKY_KEY=
PACKY_BASE_URL=https://www.packyapi.com/v1
DEEPSEEK_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ZHICHUANG_KEY=
ZHICHUANG_BASE_URL=https://s.lconai.com/v1

# Prompt 双轨切流:v1 = 旧 prompt,v2 = 新 prompt(本次升级)
EXAM_GEN_PROMPT_ANALYZER=v2
EXAM_GEN_PROMPT_SCENARIO=v2
EXAM_GEN_PROMPT_GENERATOR=v2
EXAM_GEN_PROMPT_ASSEMBLER=v2
