    "core_competencies": {
        "description": "2022版课标强调的数学核心素养（初中阶段）",
        "items": [
            "数感：理解数的意义，运用数进行推断和交流",
            "符号意识：理解符号代表数量关系的意义",
            "抽象能力：用字母表示数和代数运算的过程",
            "运算能力：准确、灵活地进行数与代数的运算",
            "几何直观：利用图形理解数量关系与变化趋势",
            "空间想象力：从二维到三维的图形认知",
            "推理能力：演绎推理与合情推理",
            "数据分析观念：收集、处理数据，用样本估计总体",
            "模型思想：建立数学模型解决实际问题",
            "应用意识：将数学知识用于解决现实问题",
            "创新意识：在数学学习中发现和提出新问题"
        ]
    },
    "key_math_ideas": [
