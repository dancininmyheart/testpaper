                            "key_points": [
                                "方程与方程的解的概念",
                                "等式的基本性质",
                                "解一元一次方程的步骤（去分母、去括号、移项、合并同类项、系数化为1）",
                                "列一元一次方程解应用题（行程、工程、浓度、经济等）"
                            ]
                        },
                        {
                            "id": "A2-2",
                            "name": "二元一次方程组",
                            "grade": "七年级下",
