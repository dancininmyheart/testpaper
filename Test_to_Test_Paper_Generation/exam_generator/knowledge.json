                                "判别式 Δ=b²-4ac 与根的判定",
                                "韦达定理：x₁+x₂=-b/a，x₁·x₂=c/a",
                                "列一元二次方程解应用题"
                            ]
                        },
                        {
                            "id": "A2-4",
                            "name": "不等式与不等式组",
                            "grade": "七年级下/八年级",
                            "key_points": [
                                "不等式的概念与基本性质",
                                "解一元一次不等式",
                                "一元一次不等式组的解集（取交集）",
                                "不等式在数轴上的表示",
                                "不等式的应用"
                            ]
                        }
                    ]
                },
