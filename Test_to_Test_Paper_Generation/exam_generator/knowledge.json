            "name": "数与代数",
            "subdomains": [
                {
                    "id": "A1",
                    "name": "数与式",
                    "topics": [
                        {
                            "id": "A1-1",
                            "name": "有理数",
                            "grade": "七年级上",
                            "key_points": [
                                "有理数的定义与分类（整数、分数；正数、负数、零）",
                                "数轴的概念与表示（原点、正方向、单位长度）",
                                "绝对值的定义与几何意义",
                                "有理数大小比较",
                                "有理数的四则运算（加、减、乘、除）及运算律",
                                "有理数的乘方（幂、底数、指数）",
                                "科学记数法",
                                "近似数与有效数字"
                            ]
                        },
                        {
                            "id": "A1-2",
                            "name": "整式",
                            "grade": "七年级上",
                            "key_points": [
                                "单项式的概念（系数、次数）",
                                "多项式的概念（项、次数、常数项）",
                                "整式的加减（合并同类项、去括号）",
                                "整式的乘法（单项式与单项式、单项式与多项式、多项式与多项式）",
                                "整式的除法（单项式除以单项式、多项式除以单项式）",
                                "乘法公式：平方差公式 (a+b)(a-b)=a²-b²",
                                "乘法公式：完全平方公式 (a±b)²=a²±2ab+b²"
                            ]
                        },
                        {
                            "id": "A1-3",
                            "name": "因式分解",
                            "grade": "八年级上",
                            "key_points": [
                                "因式分解的概念与意义",
                                "提公因式法",
                                "公式法（平方差公式、完全平方公式）",
                                "分组分解法",
                                "因式分解的综合运用"
                            ]
                        },
                        {
                            "id": "A1-4",
                            "name": "分式",
                            "grade": "八年级下",
